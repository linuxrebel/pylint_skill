# Example pylintrc for pylint-skill
# Copy to your project root as .pylintrc and customize

[MASTER]
# Plugins to load
# load-plugins=pylint_django,pylint_flask

# Patterns of files to ignore
ignore-patterns=test_.*?\.py

[MESSAGES CONTROL]
# Disable specific message categories
# disable=missing-docstring,too-many-arguments

[FORMAT]
# String used as indentation unit (default: 4 spaces)
indent-string='    '

# Maximum number of characters on a single line
max-line-length=100

# Expected format of line ending
expected-line-ending-format=LF

[NAMING]
# Naming style for modules (snake_case, camelCase, PascalCase)
module-naming-style=snake_case

# Naming style for functions and methods
function-naming-style=snake_case

# Naming style for variables
variable-naming-style=snake_case

# Naming style for class attributes
attr-naming-style=snake_case

# Naming style for arguments
argument-naming-style=snake_case

# Naming style for constants
const-naming-style=UPPER_CASE

# Minimum length for function/method names
function-rgx=[a-z_][a-z0-9_]*$

# Minimum length for variable names
variable-rgx=[a-z_][a-z0-9_]*$

[DESIGN]
# Maximum number of arguments
max-args=5

# Maximum number of attributes
max-attributes=7

# Maximum number of boolean expressions in if statement
max-bool-expr=5

# Maximum number of branch for function / method body
max-branches=12

# Maximum number of locals
max-locals=15

# Maximum number of parents
max-parents=7

# Maximum number of public methods
max-public-methods=20

# Maximum number of return / yield for function / method body
max-returns=6

# Maximum number of statements in function / method body
max-statements=50

[SIMILARITIES]
# Minimum lines number d a similarity to trigger
min-similarity-lines=4

# Ignore imports when computing similarities
ignore-imports=yes

[BASIC]
# Good variable names which should always be accepted
good-names=i,j,k,ex,Run,_,x,y,z

# Bad variable names which should always be rejected
bad-names=foo,bar,baz,toto,tutu,tata

# Regular expression matching correct module names
module-rgx=[a-z_][a-z0-9_]*$

# Regular expression matching correct constant names
const-rgx=(([A-Z_][A-Z0-9_]*)|(__.*__)|(_.*))$

[LOGGING]
# Logging modules which allow %s formatting
logging-format-style=old

# Logging modules which allow {} formatting
logging-format-style=new

[REPORTS]
# Set the output format. Available formats are text, parseable, colorized, json
output-format=text

# Tells whether to display a full report or only the messages
reports=no

# Activate the evaluation score
score=yes
